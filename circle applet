import java.applet.*;
import java.awt.*;

public class MyApplet extends Applet {
    int height, width;
    
    public void init() {
        height = getSize().height;
        width = getSize().width;
        setName("MyApplet");
    }
    
    public void paint(Graphics g) {
        g.drawOval(10, 20, 120, 120);  // draws a circle (oval with equal width & height)
    }
}
